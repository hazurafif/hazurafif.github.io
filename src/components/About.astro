---
import { GlassCard } from '@/components/ui/glass-card';
import { CardContent } from '@/components/ui/card';
---

<section id="about" class="section">
  <div class="container">
    <div class="section-header">
      <p class="section-number">About</p>
      <h2>A foundation in hardware-software integration, applied to AI.</h2>
    </div>
    <div class="about-grid">
      <div class="about-text">
        <p>
          I graduated with a degree in <strong>Computer Engineering</strong> from the
          <strong>University of Indonesia</strong> (Class of 2018). Blending a strong
          foundation in hardware-software integration with modern software engineering,
          I specialize in bridging the gap between core backend systems and cutting-edge
          Artificial Intelligence.
        </p>
        <p>
          My work spans designing intelligent AI agents, building infrastructure automation
          tools, and architecting end-to-end systems for production AI workloads.
        </p>
      </div>
      <div class="about-cards">
        <GlassCard client:load>
          <CardContent class="p-6">
            <p class="text-[11px] font-semibold tracking-widest uppercase text-muted-foreground/60 mb-2">Education</p>
            <p class="font-semibold text-[15px] mb-0.5">B.Eng Computer Engineering</p>
            <p class="text-[13px] text-muted-foreground">Universitas Indonesia, 2018</p>
          </CardContent>
        </GlassCard>
        <GlassCard client:load>
          <CardContent class="p-6">
            <p class="text-[11px] font-semibold tracking-widest uppercase text-muted-foreground/60 mb-2">Focus</p>
            <p class="font-semibold text-[15px] mb-0.5">AI Agents & Infrastructure</p>
            <p class="text-[13px] text-muted-foreground">Backend systems + AI integration</p>
          </CardContent>
        </GlassCard>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  .about-text p {
    color: var(--ink-muted);
    margin-bottom: var(--space-md);
    line-height: 1.65;
  }

  .about-text strong {
    font-weight: 600;
    color: var(--ink);
  }

  .about-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
</style>
