---

const contactInfo = [
  { label: 'Email', href: 'mailto:your.email@example.com', text: 'your.email@example.com' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/yourusername', text: 'linkedin.com/in/yourusername' },
  { label: 'GitHub', href: 'https://github.com/yourusername', text: 'github.com/yourusername' },
];

---

<section id="contact" class="section contact-section">
  <div class="container">
    <div class="contact-card glass">
      <div class="contact-inner">
        <p class="contact-label">Contact</p>
        <h2 class="contact-heading">Let's talk AI, backend architecture, or the future of automation.</h2>
        <div class="contact-links">
          {contactInfo.map((item) => (
            <a href={item.href} class="contact-item" target="_blank" rel="noopener noreferrer">
              <span class="contact-item-label">{item.label}</span>
              <span class="contact-item-value">{item.text}</span>
              <span class="contact-arrow">&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding-bottom: var(--space-section);
  }

  .contact-card {
    border-radius: var(--radius-lg);
    padding: var(--space-xxl);
    max-width: 680px;
  }

  .contact-label {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.43;
    letter-spacing: -0.224px;
    color: var(--ink-muted-48);
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }

  .contact-heading {
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    line-height: 1.19;
    letter-spacing: 0.231px;
    margin-bottom: var(--space-xxl);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--divider-soft);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .contact-item:first-of-type {
    border-top: 1px solid var(--divider-soft);
  }

  .contact-item:hover {
    opacity: 0.6;
  }

  .contact-item-label {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.374px;
    color: var(--primary);
    min-width: 5rem;
  }

  .contact-item-value {
    flex: 1;
    font-size: 15px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--ink-muted-48);
  }

  .contact-arrow {
    color: var(--ink-muted-48);
    font-size: 1.125rem;
    transition: transform 0.2s;
  }

  .contact-item:hover .contact-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 480px) {
    .contact-card {
      padding: var(--space-xl);
    }

    .contact-item {
      flex-wrap: wrap;
      gap: var(--space-xs);
    }

    .contact-item-value {
      width: 100%;
      order: 3;
      font-size: 14px;
      word-break: break-all;
    }
  }
</style>
