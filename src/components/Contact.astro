---
import { GlassCard } from '@/components/ui/glass-card';
import { CardContent } from '@/components/ui/card';

const contactInfo = [
  { label: 'Email', href: 'mailto:your.email@example.com', text: 'your.email@example.com' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/yourusername', text: 'linkedin.com/in/yourusername' },
  { label: 'GitHub', href: 'https://github.com/yourusername', text: 'github.com/yourusername' },
];
---

<section id="contact" class="section">
  <div class="container">
    <GlassCard class="max-w-[640px]" client:load>
      <CardContent class="p-8">
        <p class="text-[13px] font-medium tracking-widest uppercase text-muted-foreground/60 mb-4">Contact</p>
        <h2 class="mb-8 text-[clamp(1.25rem,2.5vw,1.5rem)]">Let's talk AI, backend architecture, or the future of automation.</h2>
        <div class="flex flex-col">
          {contactInfo.map((item) => (
            <a href={item.href} class="contact-item" target="_blank" rel="noopener noreferrer">
              <span class="contact-item-label">{item.label}</span>
              <span class="contact-item-value">{item.text}</span>
              <span class="contact-arrow">&rarr;</span>
            </a>
          ))}
        </div>
      </CardContent>
    </GlassCard>
  </div>
</section>

<style>
  .contact-item {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--divider-soft);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .contact-item:first-of-type {
    border-top: 1px solid var(--divider-soft);
  }

  .contact-item:hover {
    opacity: 0.6;
  }

  .contact-item-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--primary);
    min-width: 4.5rem;
  }

  .contact-item-value {
    flex: 1;
    font-size: 14px;
    color: var(--ink-muted);
  }

  .contact-arrow {
    color: var(--ink-muted-light);
    font-size: 1rem;
    transition: transform 0.2s;
  }

  .contact-item:hover .contact-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 480px) {
    .contact-item {
      flex-wrap: wrap;
      gap: 4px;
    }

    .contact-item-value {
      width: 100%;
      order: 3;
      font-size: 13px;
      word-break: break-all;
    }
  }
</style>
