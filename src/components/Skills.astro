---
import { Badge } from "@/components/starwind/badge";

const skills = [
  'Go', 'Python', 'AI Agents', 'Infrastructure Automation',
  'Full-Stack Web Development', 'API Design', 'RBAC',
  'Zabbix', 'Git', 'Linux', 'Docker',
];
---

<section id="skills" class="scroll-mt-20 py-20 md:py-28">
  <div class="max-w-[1060px] mx-auto px-6 md:px-8">
    <div class="mb-12">
      <p class="section-label">Skills</p>
      <h2 class="text-[clamp(1.75rem,4vw,2.5rem)] leading-[1.08] -tracking-[0.03em]">Technologies I work with.</h2>
    </div>
    <div class="flex flex-wrap gap-2 max-w-[640px]">
      {skills.map((skill) => (
        <Badge variant="outline" size="md">{skill}</Badge>
      ))}
    </div>
  </div>
</section>
