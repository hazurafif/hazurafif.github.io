---

const skills = [
  { category: 'Core Languages', items: ['Go (Golang)', 'Python'] },
  { category: 'Specializations', items: ['AI Application Development', 'AI Agents', 'Infrastructure Automation'] },
  { category: 'Web Development', items: ['Full-Stack Web Development', 'API Design', 'RBAC'] },
  { category: 'Tools & Monitoring', items: ['Zabbix', 'Git'] },
];

---

<section id="skills" class="section skills">
  <div class="container">
    <h2 class="section-title">Skills & Tech Stack</h2>
    <div class="skills-grid">
      {skills.map((group) => (
        <div class="skill-group">
          <h3 class="skill-category">{group.category}</h3>
          <ul class="skill-items">
            {group.items.map((item) => <li class="skill-item">{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  .skill-group {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: var(--space-lg) var(--space-xl);
  }

  .skill-category {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: var(--space-md);
  }

  .skill-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .skill-item {
    font-size: 0.9375rem;
    color: var(--text);
    position: relative;
    padding-left: 1rem;
  }

  .skill-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent-soft);
  }
</style>
