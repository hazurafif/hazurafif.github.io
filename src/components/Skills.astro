---

const skillGroups = [
  {
    category: 'Languages',
    items: ['Go (Golang)', 'Python'],
  },
  {
    category: 'AI & Specialization',
    items: ['AI Application Development', 'AI Agents', 'Infrastructure Automation'],
  },
  {
    category: 'Web & Backend',
    items: ['Full-Stack Web Development', 'API Design', 'RBAC'],
  },
  {
    category: 'Tools',
    items: ['Zabbix', 'Git'],
  },
];

---

<section id="skills" class="section">
  <div class="container">
    <div class="section-header">
      <p class="section-number">Skills</p>
      <h2 class="section-title">Technologies I work with.</h2>
    </div>
    <div class="skills-grid">
      {skillGroups.map((group) => (
        <div class="skill-group glass">
          <p class="skill-category">{group.category}</p>
          <div class="skill-items">
            {group.items.map((item) => (
              <p class="skill-item">{item}</p>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-number {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.43;
    letter-spacing: -0.224px;
    color: var(--ink-muted-48);
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }

  .skill-group {
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .skill-category {
    font-size: 12px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.12px;
    color: var(--ink-muted-48);
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }

  .skill-items {
    display: flex;
    flex-direction: column;
  }

  .skill-item {
    font-size: 17px;
    font-weight: 400;
    line-height: 1.47;
    letter-spacing: -0.374px;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--divider-soft);
  }

  .skill-item:last-child {
    border-bottom: none;
  }
</style>
