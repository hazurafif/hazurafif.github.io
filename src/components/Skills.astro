---

const skillGroups = [
  { category: 'Languages', items: ['Go (Golang)', 'Python'] },
  { category: 'AI & Specialization', items: ['AI Application Development', 'AI Agents', 'Infrastructure Automation'] },
  { category: 'Web & Backend', items: ['Full-Stack Web Development', 'API Design', 'RBAC'] },
  { category: 'Tools', items: ['Zabbix', 'Git'] },
];

---

<section id="skills" class="py-12 md:py-16">
  <div class="max-w-[1060px] mx-auto px-6 md:px-8">
    <div class="mb-8">
      <p class="section-number">Skills</p>
      <h2>Technologies I work with.</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {skillGroups.map((group) => (
        <div class="glass rounded-[14px] p-6">
          <p class="text-[11px] font-semibold tracking-widest uppercase text-ink-muted-light mb-4">{group.category}</p>
          <div class="flex flex-col">
            {group.items.map((item) => (
              <p class="text-[15px] py-2 border-b border-divider last:border-b-0">{item}</p>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
