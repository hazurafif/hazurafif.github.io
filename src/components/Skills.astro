---

const skillGroups = [
  {
    category: 'Languages',
    items: ['Go (Golang)', 'Python'],
  },
  {
    category: 'AI & Specialization',
    items: ['AI Application Development', 'AI Agents', 'Infrastructure Automation'],
  },
  {
    category: 'Web & Backend',
    items: ['Full-Stack Web Development', 'API Design', 'RBAC'],
  },
  {
    category: 'Tools',
    items: ['Zabbix', 'Git'],
  },
];

---

<section id="skills" class="section">
  <div class="container">
    <div class="section-header">
      <p class="section-number">Skills</p>
      <h2>Technologies I work with.</h2>
    </div>
    <div class="skills-grid">
      {skillGroups.map((group) => (
        <div class="glass rounded-xl p-6">
          <p class="text-[11px] font-semibold tracking-widest uppercase text-[var(--ink-muted-light)] mb-4">{group.category}</p>
          <div class="flex flex-col">
            {group.items.map((item) => (
              <p class="text-[15px] py-2 border-b border-[var(--divider-soft)] last:border-b-0">{item}</p>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
