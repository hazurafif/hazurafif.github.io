---
const links = [
  { href: '/', label: 'Home' },
  { href: '/#about', label: 'About' },
  { href: '/#experience', label: 'Experience' },
  { href: '/#projects', label: 'Work' },
  { href: '/#contact', label: 'Contact' },
];
---

<header class="header">
  <nav class="container nav">
    <a href="/" class="logo">hazurafif</a>
    <ul class="nav-links">
      {links.map((link) => (
        <li><a href={link.href} class="nav-link">{link.label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .header {
    padding: 1.5rem 0;
    position: sticky;
    top: 0;
    background: rgba(252, 252, 250, 0.85);
    backdrop-filter: blur(8px);
    z-index: 100;
  }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text);
  }

  .logo:hover {
    color: var(--accent);
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: var(--space-lg);
  }

  .nav-link {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--text);
  }
</style>
