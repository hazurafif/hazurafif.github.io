---
const links = [
  { href: '/', label: 'Home' },
  { href: '/#projects', label: 'Projects' },
  { href: '/#skills', label: 'Skills' },
  { href: '/about', label: 'About' },
  { href: '/#contact', label: 'Contact' },
];
---

<header>
  <nav class="container-wide nav">
    <a href="/" class="logo">hazurafif</a>
    <ul class="nav-links">
      {links.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<style>
  header {
    padding: var(--space-lg) 0;
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 100;
    border-bottom: 1px solid var(--border);
  }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text);
  }

  .logo:hover {
    color: var(--accent);
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: var(--space-lg);
  }

  .nav-links a {
    font-size: 0.9375rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--text);
  }
</style>
