---

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <p class="footer-copy">&copy; {year} Hanif Zufar Rafif</p>
    <p class="footer-built">Built with Astro &middot; Hosted on GitHub Pages</p>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-xxl) 0;
    background: var(--canvas);
    border-top: 1px solid var(--hairline);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .footer-copy {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.43;
    letter-spacing: -0.224px;
    color: var(--ink-muted-48);
  }

  .footer-built {
    font-size: 12px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.12px;
    color: var(--ink-muted-48);
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
