---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, icon, tags, liveUrl, repoUrl } = project.data;
---

<article class="project-card glass">
  <div class="card-body">
    <p class="card-icon">{icon || '📁'}</p>
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
  </div>
  <div class="card-footer">
    <div class="card-tags">
      {tags.map((tag) => <span class="tag glass">{tag}</span>)}
    </div>
    {(repoUrl || liveUrl) && (
      <div class="card-links">
        {repoUrl && <a href={repoUrl} class="card-link" target="_blank" rel="noopener noreferrer">Source</a>}
        {liveUrl && <a href={liveUrl} class="card-link" target="_blank" rel="noopener noreferrer">Live &nearr;</a>}
      </div>
    )}
  </div>
</article>

<style>
  .project-card {
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
  }

  .card-icon {
    font-size: 2rem;
    margin-bottom: var(--space-lg);
    line-height: 1;
  }

  .card-title {
    font-weight: 600;
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    line-height: 1.19;
    letter-spacing: 0.231px;
    margin-bottom: var(--space-sm);
  }

  .card-desc {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--ink-muted-48);
  }

  .card-footer {
    margin-top: var(--space-xl);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  .tag {
    font-size: 12px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.12px;
    padding: 0.35em 0.8em;
    border-radius: var(--radius-pill);
    color: var(--ink-muted-48);
  }

  .card-links {
    display: flex;
    gap: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--divider-soft);
  }

  .card-link {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.374px;
    color: var(--primary);
    transition: opacity 0.2s;
  }

  .card-link:hover {
    opacity: 0.7;
    color: var(--primary);
  }

  @media (max-width: 480px) {
    .project-card {
      padding: var(--space-lg);
    }
  }
</style>
