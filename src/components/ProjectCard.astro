---
import type { CollectionEntry } from 'astro:content';
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent } from "@/components/starwind/card";

export interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, icon, tags, liveUrl, repoUrl } = project.data;
---

<Card class="flex flex-col justify-between transition-all duration-300 hover:-translate-y-0.5 p-6" size="sm">
  <CardContent class="p-0">
    <p class="text-[1.5rem] mb-4 leading-none">{icon || '📁'}</p>
    <h3 class="text-base font-semibold mb-2 leading-snug tracking-tight">{title}</h3>
    <p class="text-sm text-muted-foreground leading-relaxed">{description}</p>
  </CardContent>
  <div class="mt-6">
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.map((tag) => <Badge variant="secondary" size="sm">{tag}</Badge>)}
    </div>
    {(repoUrl || liveUrl) && (
      <div class="flex gap-4 pt-4 border-t border-border">
        {repoUrl && <a href={repoUrl} class="text-sm font-medium text-primary no-underline hover:opacity-70 transition-opacity" target="_blank" rel="noopener noreferrer">Source</a>}
        {liveUrl && <a href={liveUrl} class="text-sm font-medium text-primary no-underline hover:opacity-70 transition-opacity" target="_blank" rel="noopener noreferrer">Live &nearr;</a>}
      </div>
    )}
  </div>
</Card>
