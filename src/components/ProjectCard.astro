---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, icon, tags, liveUrl, repoUrl } = project.data;
---

<article class="project-card glass">
  <div>
    <p class="card-icon">{icon || '📁'}</p>
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
  </div>
  <div class="card-footer">
    <div class="card-tags">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
    {(repoUrl || liveUrl) && (
      <div class="card-links">
        {repoUrl && <a href={repoUrl} class="card-link" target="_blank" rel="noopener noreferrer">Source</a>}
        {liveUrl && <a href={liveUrl} class="card-link" target="_blank" rel="noopener noreferrer">Live &nearr;</a>}
      </div>
    )}
  </div>
</article>

<style>
  .project-card {
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.25s, box-shadow 0.25s;
  }

  .project-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.06);
  }

  .card-icon {
    font-size: 1.75rem;
    margin-bottom: var(--space-md);
    line-height: 1;
  }

  .card-title {
    margin-bottom: var(--space-sm);
  }

  .card-desc {
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.55;
  }

  .card-footer {
    margin-top: var(--space-lg);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: var(--space-md);
  }

  .tag {
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-muted);
    background: var(--canvas-soft);
    padding: 4px 10px;
    border-radius: var(--radius-pill);
  }

  .card-links {
    display: flex;
    gap: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--divider-soft);
  }

  .card-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--primary);
  }

  .card-link:hover {
    opacity: 0.7;
  }
</style>
