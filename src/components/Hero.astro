---
import { Button } from '@/components/ui/button';
---

<section class="hero">
  <div class="container hero-inner">
    <div>
      <p class="hero-greeting">Hi, I'm</p>
      <h1 class="hero-name">Hanif Zufar Rafif</h1>
      <p class="hero-title">Computer Engineer & AI Application Engineer</p>
      <p class="hero-desc">
        I build intelligent automation, scalable AI agents, and robust full-stack applications that bridge backend systems with cutting-edge AI.
      </p>
      <div class="hero-actions">
        <Button variant="default" size="lg" as-child>
          <a href="/#projects">See my work</a>
        </Button>
        <Button variant="outline" size="lg" as-child>
          <a href="/#contact">Get in touch</a>
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 85vh;
    display: flex;
    align-items: center;
    background: var(--canvas-soft);
    padding-top: 80px;
  }

  .hero-inner {
    width: 100%;
  }

  .hero-greeting {
    font-size: 15px;
    font-weight: 500;
    color: var(--primary);
    margin-bottom: var(--space-sm);
  }

  .hero-name {
    margin-bottom: var(--space-md);
    max-width: 700px;
  }

  .hero-title {
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--ink-muted);
    margin-bottom: var(--space-md);
    max-width: 550px;
  }

  .hero-desc {
    color: var(--ink-muted);
    max-width: 500px;
    margin-bottom: var(--space-xl);
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 90vh;
      padding-top: 100px;
    }
  }
</style>
