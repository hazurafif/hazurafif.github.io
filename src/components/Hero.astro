---

---

<section class="hero">
  <div class="hero-glow"></div>
  <div class="container">
    <p class="hero-greeting">Hi, I'm</p>
    <h1 class="hero-name">Hanif Zufar<br />Rafif</h1>
    <p class="hero-title">Computer Engineer & AI Application Engineer</p>
    <p class="hero-desc">
      I build intelligent automation, scalable AI agents, and robust full-stack applications that bridge backend systems with cutting-edge AI.
    </p>
    <div class="hero-actions">
      <a href="/#projects" class="btn btn-primary">See my work</a>
      <a href="/#contact" class="btn btn-outline">Get in touch</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    background: var(--canvas-parchment);
    overflow: hidden;
    padding-top: 80px;
  }

  .hero-glow {
    position: absolute;
    top: -30%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0, 102, 204, 0.08) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-greeting {
    font-size: 17px;
    font-weight: 400;
    letter-spacing: -0.374px;
    color: var(--primary);
    margin-bottom: var(--space-sm);
  }

  .hero-name {
    max-width: 800px;
    margin-bottom: var(--space-lg);
  }

  .hero-title {
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 600;
    line-height: 1.19;
    letter-spacing: 0.231px;
    color: var(--ink-muted-48);
    margin-bottom: var(--space-lg);
    max-width: 600px;
  }

  .hero-desc {
    font-size: 17px;
    font-weight: 400;
    line-height: 1.47;
    letter-spacing: -0.374px;
    color: var(--ink-muted-48);
    max-width: 540px;
    margin-bottom: var(--space-xl);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 90vh;
      align-items: flex-start;
    }

    .hero-glow {
      width: 400px;
      height: 400px;
      top: -20%;
      right: -20%;
    }
  }
</style>
