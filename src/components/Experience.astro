<section id="experience" class="section experience">
  <div class="container">
    <h2 class="section-title">Work Experience</h2>
    <div class="experience-card">
      <div class="experience-header">
        <h3>AI Application Engineer</h3>
        <span class="experience-meta">Full-Time &middot; June 2023 – Present</span>
      </div>
      <ul class="experience-list">
        <li>
          <strong>AI Agents & Chat Ecosystems:</strong> Design, develop, and deploy intelligent AI agents and conversational applications tailored to solve complex user needs.
        </li>
        <li>
          <strong>Infrastructure Automation:</strong> Architected and developed Zabbix automation tools to streamline system monitoring, alerting, and operational efficiency.
        </li>
        <li>
          <strong>Full-Stack Implementation:</strong> Build and maintain the end-to-end architecture required to support high-performance AI models in production.
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .experience-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: var(--space-xl);
    max-width: 600px;
  }

  .experience-header {
    margin-bottom: var(--space-lg);
  }

  .experience-header h3 {
    font-weight: 500;
    margin-bottom: var(--space-xs);
  }

  .experience-meta {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .experience-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .experience-list li {
    position: relative;
    padding-left: 1.25rem;
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .experience-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-soft);
  }
</style>
