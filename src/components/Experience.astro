<style>
  .experience-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: var(--space-xl);
    max-width: 680px;
  }

  .exp-head {
    margin-bottom: var(--space-lg);
  }

  .exp-head h3 {
    font-weight: 700;
    margin-bottom: var(--space-xs);
  }

  .exp-meta {
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }

  .exp-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .exp-items li {
    display: flex;
    gap: var(--space-md);
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .exp-bullet {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    margin-top: 0.6em;
  }

  .exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tag {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.25em 0.7em;
    border-radius: 4px;
  }
</style>
