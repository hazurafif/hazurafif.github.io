<section id="experience" class="section">
  <div class="container">
    <div class="section-header">
      <p class="section-number">Experience</p>
      <h2 class="section-title">Currently building AI systems in production.</h2>
    </div>
    <div class="exp-card glass">
      <div class="exp-head">
        <h3 class="exp-role">AI Application Engineer</h3>
        <p class="exp-meta">Full-Time &middot; June 2023 – Present</p>
      </div>
      <ul class="exp-items">
        <li>
          <span class="exp-dot"></span>
          <span><strong>AI Agents & Chat Ecosystems:</strong> Design, develop, and deploy intelligent AI agents and conversational applications tailored to solve complex user needs.</span>
        </li>
        <li>
          <span class="exp-dot"></span>
          <span><strong>Infrastructure Automation:</strong> Architected and developed Zabbix automation tools to streamline system monitoring, alerting, and operational efficiency.</span>
        </li>
        <li>
          <span class="exp-dot"></span>
          <span><strong>Full-Stack Implementation:</strong> Build and maintain the end-to-end architecture required to support high-performance AI models in production.</span>
        </li>
      </ul>
      <div class="exp-tags">
        <span class="tag glass">Go</span>
        <span class="tag glass">Python</span>
        <span class="tag glass">AI Agents</span>
        <span class="tag glass">Zabbix</span>
        <span class="tag glass">Full-Stack</span>
      </div>
    </div>
  </div>
</section>

<style>
  .section-number {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.43;
    letter-spacing: -0.224px;
    color: var(--ink-muted-48);
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
  }

  .exp-card {
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    max-width: 680px;
  }

  .exp-head {
    margin-bottom: var(--space-xl);
  }

  .exp-role {
    font-weight: 600;
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    line-height: 1.19;
    letter-spacing: 0.231px;
    margin-bottom: var(--space-xxs);
  }

  .exp-meta {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.43;
    letter-spacing: -0.224px;
    color: var(--ink-muted-48);
  }

  .exp-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .exp-items li {
    display: flex;
    gap: var(--space-sm);
    color: var(--ink-muted-48);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.5;
  }

  .exp-items strong {
    font-weight: 600;
    color: var(--ink);
  }

  .exp-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--primary);
    margin-top: 0.55em;
  }

  .exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .tag {
    font-size: 12px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.12px;
    padding: 0.35em 0.8em;
    border-radius: var(--radius-pill);
    color: var(--ink-muted-48);
  }
</style>
