---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { Button } from "@/components/starwind/button";
---

<BaseLayout title="404 — Page not found">
  <Header />
  <main>
    <section class="min-h-[80vh] flex items-center py-24">
      <div class="max-w-[1060px] mx-auto px-6 md:px-8 flex justify-center">
        <div class="text-center max-w-[440px]">
          <p class="text-[clamp(4rem,10vw,6rem)] font-bold leading-none text-primary mb-4">404</p>
          <h1 class="text-[clamp(1.5rem,3vw,2rem)] leading-[1.08] -tracking-[0.03em] mb-3">Page not found</h1>
          <p class="text-ink-muted mb-8">The page you're looking for doesn't exist or has been moved.</p>
          <Button href="/" variant="primary" size="lg">Go Home &rarr;</Button>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
