---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
---

<BaseLayout title="404 — Page not found">
  <Header />
  <main>
    <section class="nf-section">
      <div class="container flex justify-center">
        <div class="glass rounded-xl p-8 max-w-[440px] text-center">
          <p class="text-[clamp(3.5rem,8vw,5rem)] font-bold leading-none text-[var(--primary)] mb-4">404</p>
          <h1 class="mb-3">Page not found</h1>
          <p class="text-[var(--ink-muted)] mb-6">The page you're looking for doesn't exist or has been moved.</p>
          <a href="/" class="nf-cta">Go Home &rarr;</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .nf-section {
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: 100px 0;
  }

  .nf-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 500;
    padding: 10px 20px;
    border-radius: 9999px;
    text-decoration: none;
    background: #0066cc;
    color: #fff;
    border: 1px solid #0066cc;
    transition: background 0.2s;
  }

  .nf-cta:hover {
    background: #0071e3;
    color: #fff;
  }
</style>
