---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { GlassCard } from '@/components/ui/glass-card';
import { CardContent } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
---

<BaseLayout title="404 — Page not found">
  <Header />
  <main>
    <section class="nf-section">
      <div class="container flex justify-center">
        <GlassCard class="max-w-[440px] text-center" client:load>
          <CardContent class="p-8">
            <p class="text-[clamp(3.5rem,8vw,5rem)] font-bold leading-none text-primary mb-4">404</p>
            <h1 class="mb-3">Page not found</h1>
            <p class="text-muted-foreground mb-6">The page you're looking for doesn't exist or has been moved.</p>
            <Button variant="default" size="lg" as-child>
              <a href="/">Go Home &rarr;</a>
            </Button>
          </CardContent>
        </GlassCard>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .nf-section {
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: 100px 0;
  }
</style>
