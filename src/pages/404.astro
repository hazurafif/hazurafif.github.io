---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
---

<BaseLayout title="404 — Page not found">
  <Header />
  <main>
    <section class="min-h-[80vh] flex items-center py-24 scroll-offset">
      <div class="max-w-[1060px] mx-auto px-6 md:px-8 flex justify-center">
        <div class="glass rounded-[14px] p-8 max-w-[440px] text-center">
          <p class="text-[clamp(3.5rem,8vw,5rem)] font-bold leading-none text-primary mb-4">404</p>
          <h1 class="mb-3">Page not found</h1>
          <p class="text-ink-muted mb-6">The page you're looking for doesn't exist or has been moved.</p>
          <a href="/" class="inline-flex items-center justify-center text-sm font-medium px-5 py-2.5 rounded-full no-underline bg-primary text-white border border-primary hover:bg-primary-hover hover:text-white transition-all">Go Home &rarr;</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
