---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} — Hanif Zufar Rafif`} description={project.data.description}>
  <Header />
  <main>
    <article class="section project-page">
      <div class="container">
        <a href="/#projects" class="back-link">&larr; Back</a>
        <header class="project-head">
          <h1 class="project-title">{project.data.title}</h1>
          <div class="project-meta">
            <time datetime={project.data.pubDate.toISOString()}>
              {project.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
            </time>
          </div>
          {project.data.tags && (
            <div class="project-tags">
              {project.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          )}
        </header>
        <div class="project-content">
          <Content />
        </div>
        <div class="project-links">
          {project.data.liveUrl && <a href={project.data.liveUrl} class="btn btn-primary" target="_blank" rel="noopener noreferrer">Live Site &nearr;</a>}
          {project.data.repoUrl && <a href={project.data.repoUrl} class="btn btn-outline" target="_blank" rel="noopener noreferrer">Source Code &nearr;</a>}
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .project-page {
    padding-top: var(--space-2xl);
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-xl);
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .project-head {
    margin-bottom: var(--space-xl);
    max-width: 680px;
  }

  .project-title {
    margin-bottom: var(--space-sm);
  }

  .project-meta {
    margin-bottom: var(--space-md);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tag {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.25em 0.7em;
    border-radius: 4px;
  }

  .project-content {
    max-width: 680px;
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 1rem;
  }

  .project-content p {
    margin-bottom: var(--space-md);
  }

  .project-content h2 {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
    font-size: 1.5rem;
    color: var(--text);
  }

  .project-content ul {
    padding-left: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .project-content li {
    margin-bottom: var(--space-sm);
  }

  .project-links {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--border);
    max-width: 680px;
  }

  @media (max-width: 480px) {
    .project-links {
      flex-direction: column;
    }
  }
</style>
