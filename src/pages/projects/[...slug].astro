---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} — Hanif Zufar Rafif`} description={project.data.description}>
  <Header />
  <main>
    <article class="project-page">
      <div class="container">
        <div class="project-back">
          <a href="/#projects" class="back-link">&larr; Back to projects</a>
        </div>
        <header class="project-head">
          <h1 class="project-title">{project.data.title}</h1>
          <div class="project-meta">
            <time datetime={project.data.pubDate.toISOString()}>
              {project.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
            </time>
          </div>
          {project.data.tags && (
            <div class="project-tags">
              {project.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          )}
        </header>
        <div class="project-content">
          <Content />
        </div>
        <div class="project-actions">
          {project.data.liveUrl && <a href={project.data.liveUrl} class="btn-primary" target="_blank" rel="noopener noreferrer">Live Site &nearr;</a>}
          {project.data.repoUrl && <a href={project.data.repoUrl} class="btn-outline" target="_blank" rel="noopener noreferrer">Source Code &nearr;</a>}
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .project-page {
    padding: 120px 0 var(--space-huge);
  }

  .project-back {
    margin-bottom: var(--space-xxl);
  }

  .back-link {
    font-size: 14px;
    font-weight: 460;
    font-variation-settings: 'wght' 460;
    line-height: 1.4;
    color: var(--ink-mute);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--ink);
  }

  .project-head {
    margin-bottom: var(--space-xxl);
    max-width: 680px;
  }

  .project-title {
    margin-bottom: var(--space-lg);
  }

  .project-meta {
    margin-bottom: var(--space-lg);
    font-size: 14px;
    font-weight: 460;
    font-variation-settings: 'wght' 460;
    line-height: 1.4;
    color: var(--ink-mute);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tag {
    font-size: 12px;
    font-weight: 540;
    font-variation-settings: 'wght' 540;
    line-height: 1.4;
    color: var(--ink-mute);
    background: var(--canvas-soft);
    padding: 0.3em 0.7em;
    border-radius: var(--radius-xs);
  }

  .project-content {
    max-width: 680px;
    color: var(--ink-mute);
    font-size: 16px;
    font-weight: 460;
    font-variation-settings: 'wght' 460;
    line-height: 1.5;
  }

  .project-content p {
    margin-bottom: var(--space-lg);
  }

  .project-content h2 {
    margin-top: var(--space-xxl);
    margin-bottom: var(--space-lg);
    color: var(--ink);
  }

  .project-content ul {
    padding-left: var(--space-xl);
    margin-bottom: var(--space-lg);
  }

  .project-content li {
    margin-bottom: var(--space-sm);
  }

  .project-actions {
    display: flex;
    gap: var(--space-lg);
    margin-top: var(--space-xxl);
    padding-top: var(--space-xxl);
    border-top: 1px solid var(--hairline);
    max-width: 680px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 12px 20px;
    font-size: 16px;
    font-weight: 700;
    font-variation-settings: 'wght' 700;
    line-height: 1;
    color: var(--on-primary);
    background: var(--primary);
    border: none;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-primary:hover {
    background: var(--primary-deep);
    color: var(--on-primary);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    padding: 12px 20px;
    font-size: 16px;
    font-weight: 700;
    font-variation-settings: 'wght' 700;
    line-height: 1;
    color: var(--ink);
    background: var(--canvas);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .btn-outline:hover {
    border-color: var(--ink);
  }

  @media (max-width: 480px) {
    .project-actions {
      flex-direction: column;
    }

    .project-page {
      padding-top: 100px;
    }
  }
</style>
