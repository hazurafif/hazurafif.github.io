---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} — Hanif Zufar Rafif`}>
  <Header />
  <main>
    <article class="project-page">
      <div class="container">
        <a href="/#projects" class="back-link">&larr; Back</a>
        <div class="project-card glass">
          <header class="project-head">
            <h1 class="project-title">{project.data.title}</h1>
            <div class="project-meta">
              <time datetime={project.data.pubDate.toISOString()}>
                {project.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
              </time>
            </div>
            {project.data.tags && (
              <div class="project-tags">
                {project.data.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            )}
          </header>
          <div class="project-content">
            <Content />
          </div>
          <div class="project-actions">
            {project.data.liveUrl && <a href={project.data.liveUrl} class="btn btn-primary" target="_blank" rel="noopener noreferrer">Live Site &nearr;</a>}
            {project.data.repoUrl && <a href={project.data.repoUrl} class="btn btn-outline" target="_blank" rel="noopener noreferrer">Source Code &nearr;</a>}
          </div>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .project-page {
    padding: 100px 0 var(--space-xxl);
  }

  .back-link {
    display: inline-block;
    font-size: 13px;
    color: var(--ink-muted);
    margin-bottom: var(--space-lg);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--ink);
  }

  .project-card {
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    max-width: 700px;
  }

  .project-head {
    margin-bottom: var(--space-xl);
  }

  .project-title {
    margin-bottom: var(--space-md);
  }

  .project-meta {
    margin-bottom: var(--space-md);
    font-size: 13px;
    color: var(--ink-muted);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-muted);
    background: var(--canvas-soft);
    padding: 4px 10px;
    border-radius: var(--radius-pill);
  }

  .project-content {
    color: var(--ink-muted);
    font-size: 15px;
    line-height: 1.65;
  }

  .project-content p {
    margin-bottom: var(--space-md);
  }

  .project-content h2 {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
    color: var(--ink);
  }

  .project-content ul {
    padding-left: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .project-actions {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--divider-soft);
  }

  @media (max-width: 480px) {
    .project-actions {
      flex-direction: column;
    }
  }
</style>
