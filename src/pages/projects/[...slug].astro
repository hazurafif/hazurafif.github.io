---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { GlassCard } from '@/components/ui/glass-card';
import { CardContent } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} — Hanif Zufar Rafif`}>
  <Header />
  <main>
    <article class="project-page">
      <div class="container">
        <a href="/#projects" class="back-link">&larr; Back</a>
        <GlassCard class="max-w-[700px]" client:load>
          <CardContent class="p-8">
            <header class="mb-8">
              <h1 class="mb-4">{project.data.title}</h1>
              <div class="text-[13px] text-muted-foreground mb-4">
                <time datetime={project.data.pubDate.toISOString()}>
                  {project.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
                </time>
              </div>
              {project.data.tags && (
                <div class="flex flex-wrap gap-1.5">
                  {project.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              )}
            </header>
            <div class="project-content">
              <Content />
            </div>
            <div class="flex gap-3 mt-8 pt-6 border-t border-border/50">
              {project.data.liveUrl && (
                <Button variant="default" size="lg" as-child>
                  <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer">Live Site &nearr;</a>
                </Button>
              )}
              {project.data.repoUrl && (
                <Button variant="outline" size="lg" as-child>
                  <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer">Source Code &nearr;</a>
                </Button>
              )}
            </div>
          </CardContent>
        </GlassCard>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .project-page {
    padding: 100px 0 var(--space-xxl);
  }

  .back-link {
    display: inline-block;
    font-size: 13px;
    color: var(--ink-muted);
    margin-bottom: var(--space-lg);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--ink);
  }

  .tag {
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-muted);
    background: var(--canvas-soft);
    padding: 4px 10px;
    border-radius: var(--radius-pill);
  }

  .project-content {
    color: var(--ink-muted);
    font-size: 15px;
    line-height: 1.65;
  }

  .project-content p {
    margin-bottom: var(--space-md);
  }

  .project-content h2 {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
    color: var(--ink);
  }

  .project-content ul {
    padding-left: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  @media (max-width: 480px) {
    .project-content .flex {
      flex-direction: column;
    }
  }
</style>
