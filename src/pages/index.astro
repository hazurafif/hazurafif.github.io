---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Hero from '@/components/Hero.astro';
import About from '@/components/About.astro';
import Experience from '@/components/Experience.astro';
import Skills from '@/components/Skills.astro';
import Contact from '@/components/Contact.astro';
import Footer from '@/components/Footer.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
projects.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout>
  <Header />
  <main>
    <Hero />
    <About />
    <Experience />

    <section id="projects" class="scroll-mt-20 py-20 md:py-28">
      <div class="max-w-[1060px] mx-auto px-6 md:px-8">
        <div class="mb-12">
          <p class="section-label">Projects</p>
          <h2 class="text-[clamp(1.75rem,4vw,2.5rem)] leading-[1.12] -tracking-[0.02em]">Some things I've built.</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {projects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      </div>
    </section>

    <Skills />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
