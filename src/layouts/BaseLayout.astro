---
import "@/styles/starwind.css";
import '@/styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Hanif Zufar Rafif', description = 'Computer Engineer & AI Application Engineer. I build intelligent automation, scalable AI agents, and robust full-stack applications.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* Classes that Tailwind v4 content scanner doesn't detect */

  /* Starwind badge identifier */
  .starwind-badge {
    display: inline-flex;
  }

  [class*="[&_svg]:pointer-events-none"] svg {
    pointer-events: none;
  }

  [class*="[&_svg]:shrink-0"] svg {
    flex-shrink: 0;
  }

  [class*="has-[>svg]:px-4"]:has(> svg) {
    padding-left: 1rem;
    padding-right: 1rem;
  }

  /* Project content: heading and list styling via arbitrary variants */
  [class*="[&_h2]:text-ink"] h2 {
    color: #1d1d1f;
  }
  [class*="[&_h2]:text-xl"] h2 {
    font-size: 1.25rem;
  }
  [class*="[&_h2]:font-semibold"] h2 {
    font-weight: 600;
  }
  [class*="[&_h2]:mt-8"] h2 {
    margin-top: 2rem;
  }
  [class*="[&_h2]:mb-4"] h2 {
    margin-bottom: 1rem;
  }
  [class*="[&_ul]:pl-6"] ul {
    padding-left: 1.5rem;
  }
  [class*="[&_li]:mb-2"] li {
    margin-bottom: 0.5rem;
  }

  [class*="hover:shadow-[0_4px_24px_rgba(0,0,0,0.06)]"]:hover {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  [class*="-left-[calc(1rem+1px)]"] {
    left: calc(1rem + 1px);
  }

  [class*="[&_svg:not([class*='size-'])]:size-3"] svg:not([class*="size-"]) {
    width: 0.75rem;
    height: 0.75rem;
  }

  [class*="[&_svg:not([class*='size-'])]:size-4"] svg:not([class*="size-"]) {
    width: 1rem;
    height: 1rem;
  }

  [class*="[&_svg:not([class*='size-'])]:size-4.5"] svg:not([class*="size-"]) {
    width: 1.125rem;
    height: 1.125rem;
  }
</style>
